# 默认：文本文件用 LF 行尾（仓库内统一）
* text=auto eol=lf

# Windows 批处理文件必须用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 显式标记文本文件类型
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.txt text eol=lf

# 二进制文件（不做换行符转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
